#!/usr/bin/env python3
import argparse
import csv
import json
import re
from pathlib import Path


def parse_simple_yaml(path):
    data = {}
    for raw in Path(path).read_text(encoding='utf-8').splitlines():
        line = raw.strip()
        if not line or line.startswith('#') or ':' not in line:
            continue
        key, value = line.split(':', 1)
        value = value.strip().strip('"').strip("'")
        if re.fullmatch(r"-?\d+(?:\.\d+)?", value):
            if '.' in value:
                value = float(value)
            else:
                value = int(value)
        data[key.strip()] = value
    return data


def load_policy(path):
    policies = {}
    with open(path, newline='', encoding='utf-8') as f:
        for row in csv.DictReader(f):
            row['approved_cost_centers'] = [x.strip() for x in row['approved_cost_centers'].split(';') if x.strip()]
            row['po_required'] = row['po_required'].lower() == 'yes'
            row['active'] = row['active'].lower() == 'yes'
            row['secondary_approval_threshold'] = float(row['secondary_approval_threshold'])
            policies[row['vendor_id']] = row
    return policies


def audit_invoice(inv, policies):
    findings = []
    policy = policies.get(str(inv.get('vendor_id', '')).strip())
    amount = float(inv.get('amount_usd') or 0)
    if not policy:
        findings.append({'severity': 'high', 'code': 'unknown_vendor', 'message': 'Vendor ID is not present in the active policy table.'})
        return findings
    if not policy.get('active'):
        findings.append({'severity': 'high', 'code': 'inactive_vendor', 'message': 'Vendor is marked inactive in policy table.'})
    if str(inv.get('cost_center', '')).strip() not in policy['approved_cost_centers']:
        findings.append({'severity': 'high', 'code': 'cost_center_not_approved', 'message': 'Invoice cost center is not approved for this vendor.'})
    if policy['po_required'] and not str(inv.get('purchase_order', '')).strip():
        findings.append({'severity': 'medium', 'code': 'missing_purchase_order', 'message': 'Purchase order is required by policy but is absent.'})
    if amount > policy['secondary_approval_threshold'] and not str(inv.get('secondary_approval', '')).strip():
        findings.append({'severity': 'high', 'code': 'missing_secondary_approval', 'message': 'Invoice exceeds the secondary approval threshold.'})
    return findings


def main():
    ap = argparse.ArgumentParser(description='Audit migration invoices against Finance Ops policy.')
    ap.add_argument('--input-dir', required=True)
    ap.add_argument('--policy', required=True)
    ap.add_argument('--output', required=True)
    args = ap.parse_args()

    input_dir = Path(args.input_dir)
    policies = load_policy(args.policy)
    invoices = []
    for path in sorted(input_dir.glob('*.yaml')):
        inv = parse_simple_yaml(path)
        inv['source_file'] = str(path)
        findings = audit_invoice(inv, policies)
        invoices.append({
            'invoice_id': inv.get('invoice_id'),
            'vendor_name': inv.get('vendor_name'),
            'amount_usd': inv.get('amount_usd'),
            'cost_center': inv.get('cost_center'),
            'finding_count': len(findings),
            'findings': findings,
        })

    result = {
        'generated_by': 'ledger-audit',
        'input_count': len(invoices),
        'total_amount_usd': round(sum(float(x.get('amount_usd') or 0) for x in invoices), 2),
        'invoice_results': invoices,
        'summary': {
            'passed_without_findings': sum(1 for x in invoices if not x['findings']),
            'requires_review': sum(1 for x in invoices if x['findings']),
            'high_severity_findings': sum(1 for x in invoices for f in x['findings'] if f['severity'] == 'high'),
            'medium_severity_findings': sum(1 for x in invoices for f in x['findings'] if f['severity'] == 'medium'),
        }
    }
    out = Path(args.output)
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(json.dumps(result, indent=2, sort_keys=True), encoding='utf-8')
    print(f"ledger-audit completed: {len(invoices)} invoices, {result['summary']['requires_review']} require review")
    for inv in invoices:
        if inv['findings']:
            codes = ', '.join(f['code'] for f in inv['findings'])
            print(f"- {inv['invoice_id']}: {codes}")


if __name__ == '__main__':
    main()
